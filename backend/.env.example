MOCK_MODE=false

# ── MySQL (broker CRM database) ───────────────────────────────────────────────
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=crmdb

# ── MSSQL ─────────────────────────────────────────────────────────────────────
MSSQL_SERVER=
MSSQL_DATABASE=
MSSQL_USERNAME=
MSSQL_PASSWORD=
MSSQL_DRIVER=ODBC Driver 18 for SQL Server

# ── CRM API ───────────────────────────────────────────────────────────────────
CRM_API_BASE_URL=https://apicrm.cmtrading.com/SignalsCRM
CRM_API_TOKEN=

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRE_HOURS=8

# ── PostgreSQL (local) ────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=operations
POSTGRES_USER=operations
POSTGRES_PASSWORD=

# ── Replica PostgreSQL (read-only, optional) ──────────────────────────────────
REPLICA_DB_HOST=
REPLICA_DB_PORT=5432
REPLICA_DB_NAME=
REPLICA_DB_USER=
REPLICA_DB_PASSWORD=
REPLICA_DB_SSL=false

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["https://operations.cmtrading.com"]

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@cmtrading.com

# ── App URL ───────────────────────────────────────────────────────────────────
APP_BASE_URL=https://operations.cmtrading.com
